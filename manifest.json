{
  "manifest_version": 3,
  "name": "Pioneer Feeders Pack Scan",
  "version": "1.0.0",
  "description": "Badge scan overlay for packer attribution after ShipStation label creation",
  "permissions": [
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "*://*.shipstation.com/*",
    "https://web-production-9d744.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PackScan — Click to toggle ON/OFF"
  },
  "content_scripts": [
    {
      "matches": ["*://*.shipstation.com/*"],
      "js": ["injector.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["*://*.shipstation.com/*"]
    }
  ]
}
